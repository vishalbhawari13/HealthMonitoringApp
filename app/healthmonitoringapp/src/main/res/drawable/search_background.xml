<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Disabled State -->
    <item android:state_enabled="false">
        <shape android:shape="rectangle">
            <solid android:color="@color/gray_light"/> <!-- Light gray background when disabled -->
            <corners android:radius="@dimen/search_bar_radius"/>
            <stroke android:width="@dimen/search_bar_stroke_width" android:color="@color/gray_medium"/>
        </shape>
    </item>

    <!-- Pressed State -->
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/gray_medium"/> <!-- Slightly darker gray when pressed -->
            <corners android:radius="@dimen/search_bar_radius"/>
            <stroke android:width="@dimen/search_bar_stroke_width" android:color="@color/primary"/>
        </shape>
    </item>

    <!-- Focused State -->
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/white"/> <!-- White Background when focused -->
            <corners android:radius="@dimen/search_bar_radius"/>
            <stroke android:width="@dimen/search_bar_stroke_width" android:color="@color/primary"/>
        </shape>
    </item>

    <!-- Default State -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/background_light"/> <!-- Light background -->
            <corners android:radius="@dimen/search_bar_radius"/>
            <stroke android:width="1dp" android:color="@color/gray_dark"/> <!-- Subtle border -->
        </shape>
    </item>

</selector>
