<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Pressed State -->
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="#FF3700B3" /> <!-- Darker Purple when pressed -->
            <corners android:radius="12dp"/>
            <shadowColor android:color="#AA000000"/>
        </shape>
    </item>

    <!-- Focused State (when selected) -->
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <solid android:color="#D1C4E9" /> <!-- Light Purple when focused -->
            <corners android:radius="12dp"/>
        </shape>
    </item>

    <!-- Disabled State -->
    <item android:state_enabled="false">
        <shape android:shape="rectangle">
            <solid android:color="#B0BEC5" /> <!-- Muted Gray for Disabled -->
            <corners android:radius="12dp"/>
        </shape>
    </item>

    <!-- Default State -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#6200EE" /> <!-- Default Deep Purple -->
            <corners android:radius="12dp"/>
        </shape>
    </item>

</selector>
